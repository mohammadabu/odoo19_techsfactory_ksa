                <p t-if="o.partner_bank_id.beneficiary_ar" style="font-weight: normal !important;color: gray !important;margin: 10px 0px 10px 0px !important;font-size: 14px !important;"><span t-field="o.partner_bank_id.beneficiary_ar"></span></p>
